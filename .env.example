# GEMINI_API_KEY: Required for Gemini AI API calls when using direct API mode.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_PROXY_URL: Optional. If configured, routes Gemini requests securely 
# through your deployed Google Account Authenticated Firebase Cloud Function proxy.
# Example: https://us-central1-your-project-id.cloudfunctions.net/
FIREBASE_PROXY_URL=https://us-central1-your-project-id.cloudfunctions.net/
