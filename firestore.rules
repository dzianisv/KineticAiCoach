rules_version = '2';

// KineticAiCoach Firestore security rules.
// All app data lives under users/{uid}/** (workoutSessions, program, classes, messages).
// Each authenticated user (Google or anonymous) may read/write only their own subtree.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
